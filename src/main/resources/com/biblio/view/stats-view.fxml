<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.biblio.controller.StatsController"
      spacing="20" alignment="CENTER" style="-fx-padding: 30;">
    <Label text="Tableau de Bord" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
    <HBox spacing="30" alignment="CENTER">
        <VBox alignment="CENTER" spacing="5" style="-fx-background-color: #3498db; -fx-padding: 20; -fx-background-radius: 10;">
            <Label text="Total Livres" style="-fx-text-fill: white;"/>
            <Label fx:id="totalLivresLabel" text="0" style="-fx-text-fill: white; -fx-font-size: 36; -fx-font-weight: bold;"/>
        </VBox>
        <VBox alignment="CENTER" spacing="5" style="-fx-background-color: #e67e22; -fx-padding: 20; -fx-background-radius: 10;">
            <Label text="Emprunts en cours" style="-fx-text-fill: white;"/>
            <Label fx:id="empruntsEnCoursLabel" text="0" style="-fx-text-fill: white; -fx-font-size: 36; -fx-font-weight: bold;"/>
        </VBox>
        <VBox alignment="CENTER" spacing="5" style="-fx-background-color: #2ecc71; -fx-padding: 20; -fx-background-radius: 10;">
            <Label text="Emprunts rendus" style="-fx-text-fill: white;"/>
            <Label fx:id="empruntsRendusLabel" text="0" style="-fx-text-fill: white; -fx-font-size: 36; -fx-font-weight: bold;"/>
        </VBox>
        <VBox alignment="CENTER" spacing="5" style="-fx-background-color: #e74c3c; -fx-padding: 20; -fx-background-radius: 10;">
            <Label text="Livres indisponibles" style="-fx-text-fill: white;"/>
            <Label fx:id="livresIndisponiblesLabel" text="0" style="-fx-text-fill: white; -fx-font-size: 36; -fx-font-weight: bold;"/>
        </VBox>
    </HBox>
    <VBox spacing="10" style="-fx-padding: 20;">
        <Label text="Repartition par categorie :" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
        <ListView fx:id="statsListView" prefHeight="200"/>
    </VBox>
</VBox>